        "import numpy as np\n",
        "data = np.genfromtxt('solar proton flux data 2017.txt', skip_header=28,usecols=(3,4),dtype=str,invalid_raise=False)\n",
        "doy = data[:, 0]\n",
        "measured_flux = data[:, 1].astype(float)\n",
        "n_minutes = len(measured_flux)\n",
        "\n",
        "monte_carlo_flux = np.random.normal(\n",
        "loc = measured_flux[:, np.newaxis],\n",
        "scale = 0.10 * measured_flux[:, np.newaxis],\n",
        "size = (n_minutes, 1000)\n",
        ")\n",
        "import matplotlib.pyplot as plt\n",
        "plt.figure(figsize=(10, 6))\n",
        "plt.plot(doy, measured_flux, color='blue', label='Measured Flux')\n",
        "plt.xlabel('time_axis')\n",
        "plt.ylabel('Velocity of Proton(km/s)')\n",
        "plt.title('solar proton flux data 2017.txt')\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()"
