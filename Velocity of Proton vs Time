        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "data = np.loadtxt('solar proton flux data 2017.txt', skiprows=28, usecols=(4,))\n",
        "n_minutes=len(data)\n",
        "time_axis=np.arange(n_minutes)\n",
        "monte_carlo_matrix=np.random.normal(\n",
        "    loc=data[:, np.newaxis],\n",
        "    scale=0.10*data[:,np.newaxis],\n",
        "    size=(n_minutes,1000)\n",
        "    )\n",
        "mean_profile=np.mean(monte_carlo_matrix,axis=1)\n",
        "std_profile=np.std(monte_carlo_matrix, axis=1)\n",
        "plt.figure(figsize=(10,6))\n",
        "plt.plot(time_axis, mean_profile, color='blue',label='measured_flux')\n",
        "plt.fill_between(time_axis, mean_profile-std_profile, mean_profile+std_profile,color='blue', alpha=0.3)\n",
        "plt.xlabel('time')\n",
        "plt.ylabel('flux intensity')\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()"
      ]
